@using Microsoft.AspNetCore.Identity;
@model List<IdentityRole>

@Html.ValidationSummary(true, "", new { @class = "text-danger" })

<div class="container w-75">
	<a asp-controller="Rol" asp-action="VistaCrearRol" class="btn btn-primary mt-2 mb-2">Agregar Rol</a>

	<div class="mb-2">
		<input type="text" id="searchBox" class="form-control" placeholder="Buscar categoria..." />
	</div>

	<div class="d-flex justify-content-center mb-5" id="tablaRoles">
		@await Html.PartialAsync("_TablaRol", Model)
	</div>
</div>

<div class="modal fade" id="confirmarEliminarRolModal" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header bg-danger text-white">
				<h5 class="modal-title" id="modalLabel">Confirmar eliminación</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
			</div>
			<div class="modal-body">
				¿Estás seguro de que deseas eliminar este rol?
			</div>
			<div class="modal-footer">
				<form id="formEliminar" method="post">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
					<button type="submit" class="btn btn-danger">Eliminar</button>
				</form>
			</div>
		</div>
	</div>
</div>


@section Scripts {
	<script>
		$('#searchBox').on('keyup', function () {
			const filtro = $(this).val();
			$.get('/Admin/Rol/BuscarRol', { filtro: filtro }, function (html) {
				$('#tablaRoles').html(html);
			});
		});
	</script>

	<script>
		function setEliminarRolAction(actionUrl) {
			console.log(actionUrl);
			document.getElementById('formEliminar').action = actionUrl;
		}
	</script>
}