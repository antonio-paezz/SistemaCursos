@using SistemaDeCursos.Models
@model List<ApplicationUser>

<div class="container w-75">
    <a asp-action="VistaAgregar" asp-controller="Usuario" class="btn btn-primary mt-2 mb-2">Agregar</a>

    <div class="mb-2">
        <input type="text" id="searchBox" class="form-control" placeholder="Buscar por nombre o email..." />
    </div>

    <div id="tablaUsuarios" class="mb-5">
        @await Html.PartialAsync("_ListaUsuarios", Model)
    </div>
</div>

<!-- Modal Confirmación -->
<div class="modal fade" id="confirmarEliminarModal" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalLabel">Confirmar eliminación</h5>
                <button type="button" class="btn-close" data-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar este usuario?
            </div>
            <div class="modal-footer">
                <form id="formEliminar" method="post">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    
        function setEliminarAction(actionUrl) {
            console.log(actionUrl);
            document.getElementById('formEliminar').action = actionUrl;
        }


    document.getElementById("searchBox").addEventListener("input", function () {
        const valor = this.value;

        fetch('@Url.Action("Buscar", "Usuario", new { area = "Admin" })?filtro='
            + encodeURIComponent(valor))
            .then(res => res.text())
            .then(html => {
                document.getElementById("tablaUsuarios").innerHTML = html;
            });
    });
</script>

