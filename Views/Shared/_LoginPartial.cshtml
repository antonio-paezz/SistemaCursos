@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="" asp-controller="Carrito" asp-action="Carrito"><i class="bi bi-cart2"></i></a>
    </li>
    <li class="nav-item">
        <a  class="nav-link text-light" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a>
    </li>
    <li class="nav-item">
        <form  class="form-inline" asp-controller="Login" asp-action="CerrarSesion">
            <button  type="submit" class="nav-link btn btn-link text-light">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-light" asp-action="Registration" asp-controller="Registration">Register</a>
    </li>
    <li class="nav-item">
            <a class="nav-link text-light" asp-controller="Login" asp-action="Login">Login</a>
    </li>
}
</ul>
