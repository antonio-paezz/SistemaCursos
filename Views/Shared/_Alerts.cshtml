@if (TempData["SuccessMessage"] != null)
{
    <div class="toast align-items-center bg-success border-0 position-fixed bottom-0 end-0 m-3"
         role="alert" aria-live="assertive" aria-atomic="true" id="toastSuccess">
        <div class="d-flex">
            <div class="toast-body text-ligth">
                @TempData["SuccessMessage"]
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="Close"></button>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="toast align-items-center text-bg-danger border-0 position-fixed bottom-0 end-0 m-3"
         role="alert" aria-live="assertive" aria-atomic="true" id="toastError">
        <div class="d-flex">
            <div class="toast-body">
                @TempData["ErrorMessage"]
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="Close"></button>
        </div>
    </div>
}