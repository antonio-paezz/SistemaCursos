@model SistemaDeCursos.Models.Leccion;

@{
    string GetArchivoTipo(string mime)
    {
        if (mime == null) return "desconocido";

        if (mime.StartsWith("image")) return "imagen";
        if (mime.StartsWith("video")) return "video";
        if (mime.Contains("pdf")) return "pdf";

        // Word
        if (mime.Contains("word")) return "word";
        if (mime.Contains("officedocument.wordprocessingml")) return "word";

        // Excel
        if (mime.Contains("excel") || mime.Contains("spreadsheet")) return "excel";

        // PowerPoint
        if (mime.Contains("presentation")) return "ppt";

        // Texto
        if (mime.StartsWith("text")) return "texto";

        // Audio
        if (mime.StartsWith("audio")) return "audio";

        // ZIP, RAR
        if (mime.Contains("zip") || mime.Contains("rar")) return "zip";

        // Por defecto → archivo genérico
        return "archivo";
    }
}


<div class="w-75 mx-auto border border-1 rounded">
    <div class="bg-white border-bottom">
        <h1 class="ms-2 titulo">@Model.Titulo</h1>
        <div class="ms-2">
            <p class="text-gray">@Model.Descripcion</p>
        </div>
    </div>

    <div>
        <div class="d-flex justify-content-between align-items-center border-bottom">
            <h2 class="mt-2 ms-2 titulo">Contenido</h2>
        </div>

        @if (!Model.Contenidos.Any())
        {
            <div class="d-flex flex-column justify-content-center align-items-center">
                <p>Esta lección todavía no tiene contenido.</p>
            </div>
        }
        else
        {
            foreach (var c in Model.Contenidos)
            {
                var tipo = GetArchivoTipo(c.Tipo);

                <div class="border border-1 p-2 mb-2">

                    @switch (tipo)
                    {
                        case "texto":
                            <p>@c.Texto</p>
                            break;

                        case "imagen":
                            <img src="@c.UrlArchivo" class="img-fluid rounded" />
                            break;

                        case "video":
                            <video controls class="w-100">
                                <source src="@c.UrlArchivo">
                            </video>
                            break;

                        case "pdf":
                            <a href="@c.UrlArchivo" download class="btn btn-outline-primary">Descargar PDF</a>
                            break;

                        case "word":
                            <a href="@c.UrlArchivo" target="_blank" class="btn btn-outline-secondary">Abrir Word</a>
                            break;

                        case "excel":
                            <a href="@c.UrlArchivo" target="_blank" class="btn btn-outline-success">Abrir Excel</a>
                            break;

                        case "ppt":
                            <a href="@c.UrlArchivo" target="_blank" class="btn btn-warning">Abrir PowerPoint</a>
                            break;

                        case "zip":
                            <a href="@c.UrlArchivo" download class="btn btn-dark">Descargar archivo</a>
                            break;

                        default:
                            <a href="@c.UrlArchivo" download class="btn btn-secondary">Descargar archivo</a>
                            break;
                    }
                </div>
            }
        }
    </div>
</div>
<div class="w-75 mx-auto d-flex justify-content-between">
    <a asp-action="AnteriorLeccion" asp-controller="Leccion" asp-route-idCurso="@Model.CursoId" asp-route-idLeccion="@Model.Id" class="text-decoration-none">Anterior lección</a>
    <a asp-action="SiguienteLeccion" asp-controller="Leccion" asp-route-idCurso="@Model.CursoId" asp-route-idLeccion="@Model.Id" class="text-decoration-none">Siguiente lección</a>
</div>
