@model SistemaDeCursos.Areas.Admin.ViewModels.AgregarCursoViewModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0 text-center">Crear nuevo curso</h4>
                </div>

                <div class="card-body">

                    <form method="post" asp-action="Crear" enctype="multipart/form-data">

                        <!-- Categoría -->
                        <div class="mb-3">
                            <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select">
                                <option disabled selected value="">-- Seleccione una categoría --</option>
                                @foreach (var c in Model.Categorias)
                                {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                        </div>

                        <!-- Título -->
                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label fw-semibold"></label>
                            <input asp-for="Titulo"
                                   class="form-control"
                                   placeholder="Ej: Curso de Desarrollo Web FullStack" />
                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                            <textarea asp-for="Descripcion"
                                      rows="4"
                                      class="form-control"
                                      placeholder="Describa brevemente el contenido del curso">
                            </textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <!-- Precio -->
                        <div class="mb-3">
                            <label asp-for="Precio" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Precio"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       class="form-control" />
                            </div>
                            <div class="form-text">
                                Ingrese 0 si el curso es gratuito.
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>

                        <!-- Imagen -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Imagen del curso</label>

                            <div class="text-center mb-3">
                                <img id="previewImagen"
                                     src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "" : Model.ImagenUrl)"
                                     class="img-fluid rounded shadow-sm @(string.IsNullOrEmpty(Model.ImagenUrl) ? "d-none" : "")"
                                     style="max-height: 250px; object-fit: cover;" />
                            </div>

                            <input type="file"
                                   asp-for="Archivo"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewFile(event)" />

                            <span asp-validation-for="Archivo" class="text-danger small"></span>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a onclick="history.back()" class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                Crear curso
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewFile(event) {
            const input = event.target;
            const preview = document.getElementById('previewImagen');

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove("d-none");
                }

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}