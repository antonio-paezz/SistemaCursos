@model ICollection<SistemaDeCursos.ViewModels.CursoViewModel>

<div class="container py-4">

    <!-- HERO -->
    <div class="bg-light rounded-4 p-4 mb-4 shadow-sm">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h2 class="fw-bold mb-1">Mis Cursos</h2>
                <p class="text-muted mb-0">
                    Gestioná, editá y administrá tus cursos publicados.
                </p>
            </div>

            <a asp-action="VistaCrear"
               asp-controller="Curso"
               class="btn btn-primary btn-lg mt-3 mt-md-0">
                <i class="bi bi-plus-circle me-1"></i> Crear nuevo curso
            </a>
        </div>

        <div class="mt-3">
            <span class="badge bg-dark">
                @Model.Count() curso(s)
            </span>
        </div>
    </div>


    @if (!Model.Any())
    {
        <!-- ESTADO VACÍO PROFESIONAL -->
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">

            <div class="mb-4">
                <i class="bi bi-journal-richtext display-1 text-primary"></i>
            </div>

            <h3 class="fw-bold">Todavía no creaste ningún curso</h3>

            <p class="text-muted mb-4">
                Compartí tu conocimiento con el mundo.
                Crear tu primer curso te llevará solo unos minutos.
            </p>

            <a asp-action="VistaCrear"
               asp-controller="Curso"
               class="btn btn-primary btn-lg">
                <i class="bi bi-rocket-takeoff me-1"></i>
                Crear mi primer curso
            </a>
        </div>
    }
    else
    {
        <!-- GRID DE CURSOS -->
        <div class="row g-4">

            @foreach (var c in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">

                        <!-- Imagen -->
                        <div style="height:180px; overflow:hidden;">
                            <img src="@c.ImagenMostrada"
                                 class="w-100 h-100 object-fit-cover"
                                 alt="@c.Titulo" />
                        </div>

                        <div class="card-body d-flex flex-column">

                            <h5 class="fw-bold">@c.Titulo</h5>

                            <p class="text-muted small flex-grow-1">
                                @(c.Descripcion?.Length > 100
                                    ? c.Descripcion.Substring(0, 100) + "..."
                                    : c.Descripcion)
                            </p>

                            <!-- Badges -->
                            <div class="mb-3">
                                <span class="badge bg-success">
                                    $@c.Precio
                                </span>

                                <span class="badge bg-secondary">
                                    @c.FechaPublicacion.ToShortDateString()
                                </span>
                            </div>

                            <!-- Acciones -->
                            <div class="d-flex gap-2">

                                <a asp-action="VistaEditar"
                                   asp-controller="Curso"
                                   asp-route-id="@c.Id"
                                   class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <button type="button"
                                        class="btn btn-outline-danger w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmarEliminarModal"
                                        onclick="setEliminarAction('@Url.Action("Eliminar", "Curso", new {area="", id = c.Id })')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                            <a asp-action="Detalle"
                               asp-controller="Curso"
                               asp-route-id="@c.Id"
                               class="btn btn-primary w-100 mt-2">
                                Ver Detalle
                            </a>

                            <a asp-action="VerCurso"
                               asp-controller="Curso"
                               asp-route-cursoId="@c.Id"
                               class="btn btn-info w-100 mt-2 text-ligth">
                                Ver Curso
                            </a>

                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>



<!-- MODAL ELIMINAR -->
<div class="modal fade" id="confirmarEliminarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    Confirmar eliminación
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                Esta acción no se puede deshacer.
                ¿Seguro que querés eliminar este curso?
            </div>

            <div class="modal-footer">
                <form id="formEliminar" method="post">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-danger">
                        Eliminar definitivamente
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>



<script>
    function setEliminarAction(actionUrl) {
        document.getElementById('formEliminar').action = actionUrl;
    }
</script>