@model SistemaDeCursos.ViewModels.EditarCursoViewModelUsu

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0 text-center">Editar curso</h4>
                </div>

                <div class="card-body">

                    <form asp-action="Editar" method="post" enctype="multipart/form-data">

                        <input type="hidden" asp-for="Id" />

                        <!-- Título -->
                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label fw-semibold"></label>
                            <input asp-for="Titulo" class="form-control" />
                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                            <textarea asp-for="Descripcion"
                                      rows="4"
                                      class="form-control">
                            </textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <!-- Precio -->
                        <div class="mb-3">
                            <label asp-for="Precio" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Precio"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       class="form-control" />
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>

                        <!-- Categoría -->
                        <div class="mb-3">
                            <label asp-for="CategoriaId" class="form-label fw-semibold"></label>
                            <select asp-for="CategoriaId" class="form-select">
                                @foreach (var c in Model.Categorias)
                                {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                        </div>

                        <!-- Imagen -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Imagen del curso</label>

                            <div class="text-center mb-3">
                                <img id="previewImagen"
                                     src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "" : Model.ImagenUrl)"
                                     class="img-fluid rounded shadow-sm @(string.IsNullOrEmpty(Model.ImagenUrl) ? "d-none" : "")"
                                     style="max-height: 250px; object-fit: cover;" />
                            </div>

                            <input type="file"
                                   asp-for="Archivo"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewFile(event)" />

                            <span asp-validation-for="Archivo" class="text-danger small"></span>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Lista"
                               asp-controller="Curso"
                               class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                Guardar cambios
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewFile(event) {
            const input = event.target;
            const preview = document.getElementById('previewImagen');

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove("d-none");
                }

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}