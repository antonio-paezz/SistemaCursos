@model SistemaDeCursos.ViewModels.CursoViewModel

<div class="container py-4">

    <!-- HERO DEL CURSO -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">

        <div style="height:250px; overflow:hidden;">
            <img src="@Model.ImagenMostrada"
                 class="w-100 h-100 object-fit-cover"
                 alt="@Model.Titulo" />
        </div>

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start flex-wrap">

                <div>
                    <h2 class="fw-bold">@Model.Titulo</h2>
                    <p class="text-muted">@Model.Descripcion</p>
                </div>

                <div class="text-end">
                    <h4 class="text-success fw-bold">$@Model.Precio</h4>
                    <span class="badge bg-dark">
                        @Model.Lecciones.Count() lección(es)
                    </span>
                </div>

            </div>

            <!-- Rating -->
            <div class="mt-3">
                @{
                    var promedio = Model.Promedio;
                    var estrellas = (int)Math.Round(promedio);
                }

                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= estrellas)
                    {
                        <i class="bi bi-star-fill text-warning"></i>
                    }
                    else
                    {
                        <i class="bi bi-star text-warning"></i>
                    }
                }

                <span class="text-muted small ms-2">
                    (@promedio.ToString("0.0"))
                </span>
            </div>

        </div>
    </div>


    <!-- SECCIÓN LECCIONES -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0">Contenido del curso</h4>

            <a asp-action="VistaCrear"
               asp-controller="Leccion"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Agregar lección
            </a>
        </div>

        <div class="card-body">

            @if (!Model.Lecciones.Any())
            {
                <!-- ESTADO VACÍO -->
                <div class="text-center py-5">

                    <i class="bi bi-collection-play display-4 text-primary mb-3"></i>

                    <h5 class="fw-bold">Este curso aún no tiene lecciones</h5>

                    <p class="text-muted">
                        Empezá agregando contenido para tus estudiantes.
                    </p>

                    <a asp-action="VistaCrear"
                       asp-controller="Leccion"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary mt-2">
                        Crear primera lección
                    </a>

                </div>
            }
            else
            {
                <!-- LISTA DE LECCIONES -->
                <div class="list-group list-group-flush">

                    @foreach (var l in Model.Lecciones)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">

                            <div>
                                <i class="bi bi-play-circle me-2 text-primary"></i>
                                <strong>@l.Titulo</strong>
                            </div>
                            
                            
                            <div>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmarEliminarModal"
                                        onclick="setEliminarAction('@Url.Action("Eliminar", "Leccion", new { id = l.Id })')">
                                    <i class="bi bi-trash"></i>
                                </button>

                                <a asp-action="Detalle"
                                   asp-controller="Leccion"
                                   asp-route-id="@l.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Ver
                                </a>
                            </div>

                        </div>
                    }

                </div>
            }

        </div>
    </div>

</div>


<!-- MODAL ELIMINAR -->
<div class="modal fade" id="confirmarEliminarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    Confirmar eliminación
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                Esta acción no se puede deshacer.
                ¿Seguro que querés eliminar esta lección? Se eliminará todo su contenido.
            </div>

            <div class="modal-footer">
                <form id="formEliminar" method="post">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-danger">
                        Eliminar definitivamente
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>


<script>
    function setEliminarAction(actionUrl) {
        document.getElementById('formEliminar').action = actionUrl;
    }
</script>