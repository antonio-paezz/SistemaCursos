@model List<SistemaDeCursos.ViewModels.CursoViewModel>

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">Mis Cursos</h2>

    @if (!Model.Any())
    {
        <div class="card shadow-sm p-5 text-center">
            <h4 class="mb-3">Todavía no estás inscrito en ningún curso</h4>
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-primary">
                Explorar cursos
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var c in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="card h-100 shadow-sm border-0">

                        <!-- Imagen -->
                        <img src="@c.ImagenMostrada"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-semibold">
                                @c.Titulo
                            </h5>

                            <!-- Promedio -->
                            <div class="mb-2">

                                @{
                                    var promedio = c.Calificaciones.Any()
                                    ? Math.Round(c.Calificaciones.Average(x => x.Puntuacion), 1)
                                    : 0;

                                    var total = c.Calificaciones.Count();
                                }

                                <div class="d-flex align-items-center">

                                    <span class="me-2 fw-semibold">
                                        @promedio
                                    </span>

                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Floor(promedio))
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else if (i - promedio < 1 && i - promedio > 0)
                                        {
                                            <i class="bi bi-star-half text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }

                                    <small class="text-muted ms-2">
                                        (@total)
                                    </small>

                                </div>

                            </div>

                            <!-- Descripción corta -->
                            <p class="text-muted small flex-grow-1">
                                @(string.IsNullOrEmpty(c.Descripcion)
                                    ? "Sin descripción disponible."
                                    : c.Descripcion.Length > 100
                                    ? c.Descripcion.Substring(0, 100) + "..."
                                    : c.Descripcion)
                            </p>

                            <!-- Botón -->
                            <a asp-action="VerCurso"
                               asp-controller="Curso"
                               asp-route-cursoId="@c.Id"
                               class="btn btn-outline-primary mt-auto w-100">
                                Ver curso
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>