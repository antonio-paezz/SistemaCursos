@model SistemaDeCursos.Models.Leccion;

@if (Model == null)
{
    <div class="ratio ratio-16x9 bg-dark">
        <div class="d-flex h-100 align-items-center justify-content-center">
            <div class="text-white text-center">
                <i class="bi bi-collection-play fs-1"></i>
                <p class="mt-2 mb-0 small">
                    Este curso aún no tiene lecciones disponibles.
                </p>
            </div>
        </div>
    </div>

    return;
}
@if (Model.Contenidos.Any(a => a.Tipo.Contains("video")))
{
    var video = Model.Contenidos.First(a => a.Tipo.StartsWith("video"));
    <div class="ratio ratio-16x9">
        <video controls>
            <source src="@video.UrlArchivo" type="video/mp4" />
        </video>
    </div>
}
else if (Model.Contenidos.Any(a => a.Tipo.Contains("pdf")))
{
    var pdf = Model.Contenidos.First(a => a.Tipo.Contains("pdf"));

    <div class="ratio ratio-16x9">
        <iframe src="@pdf.UrlArchivo" width="100%" height="100%"></iframe>
    </div>

}
else if (Model.Contenidos.Any(a => a.Tipo.Contains("image")))
{
    var image = Model.Contenidos.First(a => a.Tipo.Contains("image"));

    <div class="ratio ratio-16x9">
        <img src="@image.UrlArchivo" alt="Descripción de la imagen" width="300">
    </div>
}
else if(Model.Contenidos.Count() > 0)
{
    <div class="ratio ratio-16x9 bg-dark">
        <div class="d-flex h-100 align-items-center justify-content-center">
            <div class="text-white text-center">
                <i class="bi bi-file-earmark-text fs-1"></i>
                <p class="mt-2 mb-0 small">Esta lección contiene recursos descargables</p>
            </div>
        </div>
    </div>
    
}
else
{
    <div class="ratio ratio-16x9 bg-dark">
        <div class="d-flex h-100 align-items-center justify-content-center">
            <div class="text-white text-center">
                <i class="bi bi-folder fs-1"></i>
                <p class="mt-2 mb-0 small">Esta lección aún no tiene contenido</p>
            </div>
        </div>
    </div>
}
<h4 class="mt-3">@Model.Titulo</h4>
<p>@Model.Descripcion</p>


@if (Model.Contenidos.Any())
{
    <div class="mt-4">
        <h5>Recursos</h5>
        <ul class="list-group">
            @foreach (var archivo in Model.Contenidos)
            {
                <li class="list-group-item d-flex justify-content-between">
                    @archivo.Texto
                    <a href="@archivo.UrlArchivo" target="_blank" class="btn btn-sm btn-outline-primary">
                        Descargar
                    </a>
                </li>
            }
        </ul>
    </div>
}


