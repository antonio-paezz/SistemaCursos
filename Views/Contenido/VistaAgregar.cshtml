@model SistemaDeCursos.ViewModels.ContenidoLeccionViewModel

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Agregar contenido a la lección</h5>
        </div>

        <div class="card-body">

            <form asp-action="AgregarContenido" method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="LeccionId" />

                <!-- Texto -->
                <div class="mb-3">
                    <label asp-for="Texto" class="form-label fw-semibold">
                        Texto descriptivo (opcional)
                    </label>

                    <textarea asp-for="Texto"
                              rows="4"
                              class="form-control"
                              placeholder="Escribí una explicación, instrucciones o contenido adicional...">
                    </textarea>

                    <span asp-validation-for="Texto" class="text-danger small"></span>
                </div>

                <!-- Archivo -->
                <div class="mb-3">
                    <label asp-for="Archivo" class="form-label fw-semibold">
                        Subir archivo
                    </label>

                    <input type="file"
                           asp-for="Archivo"
                           class="form-control" />

                    <div class="form-text">
                        Podés subir videos, PDFs, imágenes u otros recursos.
                    </div>

                    <span asp-validation-for="Archivo" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a onclick="history.back()"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-success">
                        Guardar contenido
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}