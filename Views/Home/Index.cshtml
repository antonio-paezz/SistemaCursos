@model ICollection<SistemaDeCursos.ViewModels.CursoViewModel>

<!-- 🔵 HERO -->
<div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
    <div class="container-fluid py-4">
        <h1 class="display-6 fw-bold">Explorá nuevos cursos</h1>
        <p class="col-md-8 fs-5 text-muted">
            Mejorá tus habilidades con cursos creados por expertos.
        </p>
    </div>
</div>

<div class="container-fluid">
    <div class="row">

        <!-- 🟢 SIDEBAR FILTROS -->
        <div class="col-lg-3 mb-4">
            <div class="card shadow-sm border-0 p-3">

                <h5 class="fw-bold mb-3">Filtrar</h5>

                <form method="get">

                    <!-- mantener filtros activos -->
                    <input type="hidden" name="buscar" value="@Context.Request.Query["buscar"]" />

                    <!-- Orden -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ordenar por</label>
                        <select name="ordenar" class="form-select form-select-sm">
                            <option value="">Más recientes</option>
                            <option value="precioAsc">Precio menor a mayor</option>
                            <option value="precioDesc">Precio mayor a menor</option>
                            <option value="rating">Mejor valorados</option>
                        </select>
                    </div>

                    <!-- Precio mínimo -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Precio mínimo</label>
                        <input type="number" name="precioMin" class="form-control form-control-sm" />
                    </div>

                    <!-- Precio máximo -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Precio máximo</label>
                        <input type="number" name="precioMax" class="form-control form-control-sm" />
                    </div>

                    <button type="submit" class="btn btn-dark btn-sm w-100">
                        Aplicar filtros
                    </button>

                </form>
            </div>
        </div>

        <!-- 🔵 CONTENIDO PRINCIPAL -->
        <div class="col-lg-9">

            <!-- 🔢 CONTADOR RESULTADOS -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">
                    @Model.Count() cursos encontrados
                </h5>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No se encontraron cursos con los filtros seleccionados.
                </div>
            }
            else
            {
                <div class="row g-4">

                    @foreach (var c in Model)
                    {
                        bool enCarrito = ((List<int>)ViewBag.CursosEnCarrito).Contains(c.Id);

                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 shadow-sm border-0 hover-card">

                                <!-- Imagen + Badges -->
                                <div class="position-relative">

                                    <img src="@c.ImagenMostrada"
                                         class="card-img-top"
                                         style="height:200px; object-fit:cover;"
                                         alt="@c.Titulo" />

                                    <!-- Badge Destacado -->
                                    @if (c.Promedio >= 4.5 && c.TotalResenas > 3)
                                    {
                                        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">
                                            ⭐ Destacado
                                        </span>
                                    }

                                    <!-- Badge Nuevo -->
                                    @if (c.FechaPublicacion >= DateOnly.FromDateTime(DateTime.Now.AddDays(-15)))
                                    {
                                        <span class="badge bg-success position-absolute top-0 end-0 m-2">
                                            Nuevo
                                        </span>
                                    }

                                </div>

                                <div class="card-body d-flex flex-column">

                                    <h6 class="fw-bold">@c.Titulo</h6>

                                    <!-- ⭐ Estrellas -->
                                    <div class="mb-2">
                                        @if (c.TotalResenas > 0)
                                        {
                                            <span class="text-warning">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= Math.Floor(c.Promedio))
                                                    {
                                                        <i class="bi bi-star-fill"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star"></i>
                                                    }
                                                }
                                            </span>
                                            <small class="text-muted">
                                                (@c.Promedio) • @c.TotalResenas reseñas
                                            </small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Sin reseñas</small>
                                        }
                                    </div>

                                    <p class="text-muted small">
                                        @c.Descripcion
                                    </p>

                                    <div class="mt-auto">

                                        <div class="fw-bold fs-5 mb-2">
                                            $@c.Precio
                                        </div>

                                        @if (enCarrito)
                                        {
                                            <button class="btn btn-outline-secondary w-100" disabled>
                                                En el carrito
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-primary w-100 agregar-carrito"
                                                    data-id="@c.Id">
                                                Agregar al carrito
                                            </button>
                                        }

                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            }

        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: all .2s ease;
    }

        .hover-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }
</style>


@section Scripts {

    <script>
        $(document).ready(function () {

            $(".agregar-carrito").click(function () {
                const boton = $(this);
                const idCurso = boton.data("id");

                $.post("/Carrito/AgregarACarrito", { cursoId: idCurso })
                    .done(function (res) {

                        if (res.success) {
                            boton.removeClass("btn-primary")
                                .addClass("btn-secondary")
                                .text("En el carrito")
                                .prop("disabled", true);

                            toastr.success(res.message);

                        } else {
                            boton.removeClass("btn-primary")
                                .addClass("btn-secondary")
                                .text("Adquirido")
                                .prop("disabled", true);

                            toastr.warning(res.message);
                        }
                    })
                    .fail(function (xhr) {
                        if (xhr.status === 401) {
                            toastr.error("Debes Iniciar sesión para continuar.");
                            window.location.href = "/Login/Login";
                        }
                        else if (xhr.status === 403) {
                            toastr.error("No tienes permisos para realizar esta acción.");
                        }
                        else {
                            toastr.error("Ocurrió un error inesperado.");
                        }
                    });
                    
                
            });
        });

    </script>
}
